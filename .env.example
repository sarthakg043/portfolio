# Supabase project values. The publishable key is safe for browser use because
# authorization is enforced with Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only allowlist. Never rename this to a NEXT_PUBLIC_ variable.
ADMIN_EMAIL=

# Selects localhost subdomains, Vercel preview paths, or production subdomains.
# Vercel supplies VERCEL_BRANCH_URL/VERCEL_URL automatically for previews.
NEXT_DEV_MODE=development
